<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shree Tiles Service Pvt. Ltd.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Syne:wght@500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <!-- Navigation -->
  <nav>
    <div class="logo">
      SHREE TILES
      <span>SERVICE PVT. LTD.</span>
    </div>
    <button class="menu-btn" type="button" aria-label="Open menu">
      <span class="menu-lines" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span>Menu</span>
    </button>
  </nav>

  <!-- Menu Overlay -->
  <div class="menu-overlay" aria-hidden="true">
    <div class="menu-panel">
      <div class="menu-rail">
        <div>
          <div class="menu-kicker">Navigate</div>
          <div class="menu-title">Shree Tiles</div>
          <p class="menu-meta">
            A quick menu for jumping between the main parts of the site. Tap any line to close
            the menu and move straight to that section.
          </p>
        </div>
        <div class="menu-links">
          <button class="menu-link" data-section="top">
            <span>01</span>
            <span>Home</span>
          </button>
          <button class="menu-link" data-section="categories">
            <span>02</span>
            <span>Categories</span>
          </button>
          <button class="menu-link" data-section="whychoose">
            <span>03</span>
            <span>Why Choose Us</span>
          </button>
          <button class="menu-link" data-section="leadSection">
            <span>04</span>
            <span>Contact Us</span>
          </button>
        </div>
      </div>
      <div class="menu-preview">
        <img src="https://images.unsplash.com/photo-1600210492493-0946911123ea?q=80&w=1400&auto=format&fit=crop" alt="Tile showroom preview">
        <div class="overlay">
          <strong>Fast jump menu</strong>
          <span>Home · Categories · Why Choose Us · Contact</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero" id="top">
    <div class="hero-image reveal">
      <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=2000&auto=format&fit=crop" alt="Modern tile interior">
    </div>
    <h1 class="hero-title reveal">
      Tiles<br>
      For<br>
      Every Home.
    </h1>
    <p class="hero-subtitle reveal">
      Premium floor tiles, wall tiles, bathroom tiles, and designer finishes with easy
      installment support. Visit our Nagpur or Balaghat branch for expert guidance and quick
      quotations.
    </p>
  </section>

  <!-- Services / Categories -->
  <section class="services" id="categories">
    <span class="section-label reveal">Tile Categories</span>
    <img id="preview-img" src="" alt="Service Preview" class="service-preview">
    <ul class="service-list">
      <li class="service-item reveal" data-img="https://images.unsplash.com/photo-1616594039964-ae9021a400a0?q=80&w=1000&auto=format&fit=crop">Floor Tiles</li>
      <li class="service-item reveal" data-img="https://images.unsplash.com/photo-1600210492493-0946911123ea?q=80&w=1000&auto=format&fit=crop">Wall Tiles</li>
      <li class="service-item reveal" data-img="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=1000&auto=format&fit=crop">Bathroom Tiles</li>
      <li class="service-item reveal" data-img="https://images.unsplash.com/photo-1556912173-3bb406ef7e77?q=80&w=1000&auto=format&fit=crop">Kitchen Tiles</li>
      <li class="service-item reveal" data-img="https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=1000&auto=format&fit=crop">Designer Tiles</li>
    </ul>
  </section>

  <!-- Vision Section -->
  <section class="doctor">
    <div class="doc-image-wrapper reveal">
      <img src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=1000&auto=format&fit=crop" alt="Tiles showroom interior">
    </div>
    <div class="doc-info reveal">
      <span class="section-label">The Vision</span>
      <h2 class="doc-name">Shree Tiles Service Pvt. Ltd.</h2>
      <p style="color: var(--text-secondary); line-height: 1.6;">
        We help customers choose the right tile style, finish, and budget for their homes and
        projects. Our focus is simple: better selection, easier buying, and trusted local
        support.
      </p>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="trust" id="whychoose">
    <span class="section-label reveal">Why Choose Us</span>
    <div class="trust-head reveal">
      <div>
        <h2>A premium buying experience.</h2>
      </div>
      <p>
        Strong tile selection, clear support, easy inquiry flow, and a refined presentation
        that feels trustworthy.
      </p>
    </div>
    <div class="trust-grid">
      <div class="trust-card reveal">
        <h3>Easy EMI</h3>
        <p>Flexible buying support for larger tile projects and renovations.</p>
      </div>
      <div class="trust-card reveal">
        <h3>Fast Response</h3>
        <p>WhatsApp and call inquiries are the fastest path to a quotation.</p>
      </div>
      <div class="trust-card reveal">
        <h3>Two Branches</h3>
        <p>Nagpur and Balaghat locations give customers a real place to visit.</p>
      </div>
    </div>
    <div class="feature-image reveal">
      <video autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) brightness(.72);">
        <source src="https://cdn.coverr.co/videos/coverr-modern-living-room-5175/1080p.mp4" type="video/mp4">
      </video>
      <div class="feature-overlay">
        <strong>Showroom-first presentation</strong>
        <span>Now using video instead of image so it feels more premium and alive.</span>
      </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="locations">
    <span class="section-label reveal">Locations</span>
    <div class="branch-grid">
      <div class="branch-card reveal">
        <h3>Nagpur Branch</h3>
        <p>Open the branch location directly from the map link and visit for product selection.</p>
        <a href="https://maps.app.goo.gl/hZHn4gKU7qBv5tkNA" target="_blank" rel="noopener noreferrer">Open Map</a>
      </div>
      <div class="branch-card reveal">
        <h3>Balaghat Branch</h3>
        <p>Customers can open this branch location and plan a showroom visit with ease.</p>
        <a href="https://maps.app.goo.gl/fuxu86q3j5w8tWm8A" target="_blank" rel="noopener noreferrer">Open Map</a>
      </div>
    </div>
  </section>

  <!-- Lead Section -->
  <section id="leadSection" class="lead">
    <div class="lead-card reveal">
      <h3>Get a quote in one tap.</h3>
      <p>
        This lead form sends a prefilled WhatsApp message to 9623640081 with branch and tile
        selection included.
      </p>
      <form class="lead-form" id="leadForm">
        <input id="name" type="text" placeholder="Your Name" required>
        <input id="phone" type="tel" placeholder="Phone Number" required>
        <select id="branch">
          <option value="Nagpur Branch">Nagpur Branch</option>
          <option value="Balaghat Branch">Balaghat Branch</option>
        </select>
        <select id="tileType">
          <option value="Floor Tiles">Floor Tiles</option>
          <option value="Wall Tiles">Wall Tiles</option>
          <option value="Bathroom Tiles">Bathroom Tiles</option>
          <option value="Kitchen Tiles">Kitchen Tiles</option>
          <option value="Designer Tiles">Designer Tiles</option>
        </select>
        <textarea id="message" placeholder="Write your requirement, area size, budget, or any details"></textarea>
        <button class="submit-btn" type="submit">Send on WhatsApp</button>
      </form>
    </div>
    <div class="lead-side reveal">
      <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1400&auto=format&fit=crop" alt="Interior tile inspiration">
      <div class="caption">Tile-based interior image instead of code image.</div>
    </div>
  </section>

  <footer>
    <p>
      Shree Tiles Service Pvt. Ltd. · Nagpur Branch · Balaghat Branch · Premium tiles with easy
      buying support.
    </p>
  </footer>

  <!-- Floating Actions -->
  <div class="floating-actions">
    <a href="https://wa.me/919623640081?text=Hello%20Shree%20Tiles%2C%20I%20want%20a%20quote." target="_blank" rel="noopener noreferrer">WhatsApp</a>
    <a href="tel:+919623640081">Call 9623640081</a>
  </div>

  <button class="booking-trigger" id="bookingTrigger">Get Quote →</button>

  <!-- Booking Modal -->
  <div class="booking-modal" id="bookingModal">
    <div class="booking-container">
      <button class="close-btn" id="closeModal">×</button>

      <div class="step active" id="step1">
        <span class="section-label">Step 01 / 03</span>
        <h3>What do you need?</h3>
        <div class="options-grid">
          <button class="option-btn" data-need="Floor Tiles">Floor Tiles</button>
          <button class="option-btn" data-need="Wall Tiles">Wall Tiles</button>
          <button class="option-btn" data-need="Bathroom Tiles">Bathroom Tiles</button>
          <button class="option-btn" data-need="Kitchen Tiles">Kitchen Tiles</button>
          <button class="option-btn" data-need="Designer Tiles">Designer Tiles</button>
        </div>
        <button class="next-btn" data-next="2">Continue</button>
      </div>

      <div class="step" id="step2">
        <span class="section-label">Step 02 / 03</span>
        <h3>Preferred Branch</h3>
        <div class="options-grid">
          <button class="option-btn" data-branch="Nagpur Branch">Nagpur Branch</button>
          <button class="option-btn" data-branch="Balaghat Branch">Balaghat Branch</button>
        </div>
        <button class="next-btn" data-next="3">Review</button>
      </div>

      <div class="step" id="step3">
        <span class="section-label">Step 03 / 03</span>
        <h3>Finalizing</h3>
        <p style="color: var(--text-secondary); margin-bottom: 2rem;">
          Your team can reply with tile options, pricing, and EMI discussion after the customer
          submits this lead.
        </p>
        <input type="text" id="modalName" placeholder="Your Name" style="width: 100%; padding: 1rem; margin-bottom: 1rem; background: rgba(20,20,23,.96); border: 1px solid rgba(255,255,255,.18); color: white; border-radius: 12px;">
        <input type="tel" id="modalPhone" placeholder="Phone Number" style="width: 100%; padding: 1rem; margin-bottom: 1rem; background: rgba(20,20,23,.96); border: 1px solid rgba(255,255,255,.18); color: white; border-radius: 12px;">
        <textarea id="modalMessage" placeholder="Your requirement" style="width: 100%; padding: 1rem; margin-bottom: 2rem; background: rgba(20,20,23,.96); border: 1px solid rgba(255,255,255,.18); color: white; border-radius: 12px;"></textarea>
        <button class="next-btn" id="modalSubmit">Send on WhatsApp</button>
      </div>
    </div>
  </div>

  <script src="script.js"></script>
</body>
</html>
